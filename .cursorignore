# .cursorignore

# ==========================================
# 1. DEPENDENCIES & LOCK FILES
# The AI doesn't need to read other people's code
# or massive dependency trees.
# ==========================================
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb

# ==========================================
# 2. NEXT.JS (FRONTEND)
# Block all build artifacts, caches, and exports.
# ==========================================
.next/
out/
build/
.swc/
.vercel/

# ==========================================
# 3. EXPRESS.JS & WORKERS (BACKEND)
# Block compiled TypeScript, coverage, and server logs.
# ==========================================
dist/
lib/
coverage/
.nyc_output/
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# 4. STATIC DATA & HEAVY ASSETS
# Vectorizing media or massive JSON/CSV files will 
# instantly bottleneck the IDE.
# ==========================================
data
public/images/
public/videos/
public/fonts/
public/assets/
*.svg
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.mp4
*.webm
*.mp3
*.wav

# Ignore huge data dumps or seeds if you have them
*.csv
*.sql
*.sqlite
*.db
dump.json
seed-data/**/*.json

# ==========================================
# 5. OS & ENVIRONMENT SECRETS
# Keep the index clean of OS junk and prevent
# the AI from parsing environment variables.
# ==========================================
.DS_Store
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key

# ==========================================
# 6. MONOREPO TOOLING CACHES
# (If using Turborepo, Nx, or similar)
# ==========================================
.turbo/
.nx/