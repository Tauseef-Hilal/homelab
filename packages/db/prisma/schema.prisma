generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SystemStats {
  id               String @id @default(uuid())
  totalStorageUsed Int    @default(0)
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id           String   @id @default(uuid())
  role         UserRole @default(USER)
  email        String   @unique
  username     String
  password     String
  storageQuota Int
  storageUsed  Int      @default(0)
  createdAt    DateTime @default(now())

  // Relations
  files          File[]
  folders        Folder[]
  refreshTokens  RefreshToken[]
  downloadLinks  DownloadLink[]
  jobs           Job[]
  messages       BroadcastMessage[]
  uploadSessions UploadSession[]

  // Received direct user shares
  receivedUserShares UserShare[] @relation("ReceivedUserShares")
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Folder {
  id       String @id @default(uuid())
  name     String
  fullPath String
  depth    Int    @default(0)

  parentId String?
  parent   Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Folder[] @relation("FolderHierarchy")

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  files File[]

  // Separated relations
  userShares UserShare[]
  linkShares LinkShare[]

  @@unique([parentId, name, userId])
  @@unique([userId, fullPath])
  @@index([parentId])
  @@index([fullPath])
}

model File {
  id           String     @id @default(uuid())
  name         String
  mimeType     String
  size         Int
  fullPath     String
  depth        Int        @default(0)
  visibility   Visibility @default(private)
  hasThumbnail Boolean    @default(false)

  folderId String
  folder   Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  uploadSessionId String?        @unique
  uploadSession   UploadSession? @relation(fields: [uploadSessionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chunks FileChunk[]

  // Separated relations
  userShares UserShare[]
  linkShares LinkShare[]

  @@unique([userId, fullPath])
  @@unique([folderId, name, userId])
  @@index([userId, folderId])
  @@index([fullPath])
}

model FileChunk {
  id         String   @id @default(uuid())
  chunkIndex Int
  size       Int
  createdAt  DateTime @default(now())

  fileId String
  file   File   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  blobId String
  blob   Blob   @relation(fields: [blobId], references: [id], onDelete: Restrict)

  @@unique([fileId, chunkIndex])
}

model Blob {
  id        String   @id @default(uuid())
  hash      String   @unique
  blobKey   String   @unique
  size      Int
  refCount  Int
  createdAt DateTime @default(now())

  chunks FileChunk[]

  @@index([refCount])
}

model UploadSession {
  id             String       @id @default(uuid())
  totalChunks    Int
  uploadedChunks Int
  totalSize      Int
  status         UploadStatus
  expiresAt      DateTime
  createdAt      DateTime     @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  file   File?
}

enum UploadStatus {
  active
  cancelled
  completed
  expired
}

enum Visibility {
  private
  public
  shared
}

model UserShare {
  id          String    @id @default(uuid())
  permissions Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId String
  user   User   @relation("ReceivedUserShares", fields: [userId], references: [id], onDelete: Cascade)

  // Target Resource: One will be populated, the other null
  fileId String?
  file   File?   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  folderId String?
  folder   Folder? @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@unique([fileId, userId])
  @@unique([folderId, userId])
  @@index([userId])
  @@index([fileId])
  @@index([folderId])
}

model LinkShare {
  id          String    @id @default(uuid())
  token       String    @unique
  permissions Int
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?

  // Target Resource: One will be populated, the other null
  fileId String?
  file   File?   @relation(fields: [fileId], references: [id], onDelete: Cascade)

  folderId String?
  folder   Folder? @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([fileId])
  @@index([folderId])
  @@index([expiresAt])
}

model Job {
  id        String    @id @default(uuid())
  name      String
  requestId String
  attempts  Int       @default(0)
  status    JobStatus @default(enqueued)
  payload   Json
  result    Json?
  error     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum JobStatus {
  enqueued
  processing
  completed
  failed
}

model DownloadLink {
  id          String   @id @default(uuid())
  artifactKey String
  displayName String
  requestId   String
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BroadcastMessage {
  id      String   @id @default(uuid())
  content String
  sentAt  DateTime @default(now())

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
}
