{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "dist",
    "composite": true,
    "paths": {
      "@homelab/infra": ["./src"],
      "@homelab/infra/*": ["./src/*"],
      "@homelab/contracts": ["../contracts/src/index.ts"],
      "@homelab/contracts/*": ["../contracts/src/*"],
      "@homelab/storage": ["../storage/src/index.ts"],
      "@homelab/storage/*": ["../storage/src/*"]
    }
  },
  "references": [{ "path": "../contracts" }, { "path": "../storage" }],
  "include": ["src"]
}
