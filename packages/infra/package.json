{
  "name": "@homelab/infra",
  "version": "0.1.0",
  "description": "Shared runtime infrastructure for Homelab",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [],
  "author": "Tauseef Tantary",
  "license": "MIT",
  "scripts": {
    "build": "tsc -b && tsc-alias"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "require": "./dist/config/index.js",
      "default": "./dist/config/index.js"
    },
    "./logging": {
      "types": "./dist/logging/index.d.ts",
      "require": "./dist/logging/index.js",
      "default": "./dist/logging/index.js"
    },
    "./redis": {
      "types": "./dist/redis/index.d.ts",
      "require": "./dist/redis/index.js",
      "default": "./dist/redis/index.js"
    }
  },
  "dependencies": {
    "@homelab/contracts": "workspace:*",
    "dotenv": "^17.2.0",
    "ioredis": "^5.7.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "pino-rotating-file-stream": "^0.0.2",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/node": "^24.0.14",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  }
}
