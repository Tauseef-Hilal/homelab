// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SystemStats {
  id               String @id @default(uuid())
  totalStorageUsed Int    @default(0)
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id             String             @id @default(uuid())
  role           UserRole           @default(USER)
  email          String             @unique
  username       String
  password       String
  storageQuota   Int                @default(524288000)
  storageUsed    Int                @default(0)
  files          File[]
  folders        Folder[]
  createdAt      DateTime           @default(now())
  refreshTokens  RefreshToken[]
  downloadLinks  DownloadLink[]
  jobs           Job[]
  messages       BroadcastMessage[]
  uploadSessions UploadSession[]
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
}

model Folder {
  id       String  @id @default(uuid())
  name     String
  parentId String?

  parent   Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Folder[] @relation("FolderHierarchy")

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullPath String
  files    File[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([parentId, name, userId])
  @@unique([userId, fullPath])
  @@index([userId, fullPath])
  @@index([parentId])
  @@index([fullPath])
}

model File {
  id           String     @id @default(uuid())
  name         String
  mimeType     String
  size         Int
  fullPath     String
  visibility   Visibility @default(private)
  folderId     String
  folder       Folder     @relation(fields: [folderId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  hasThumbnail Boolean    @default(false)

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  SharedLink SharedLink[]

  chunks          FileChunk[]
  uploadSession   UploadSession? @relation(fields: [uploadSessionId], references: [id])
  uploadSessionId String?        @unique

  @@unique([userId, fullPath])
  @@unique([folderId, name, userId])
  @@index([userId, folderId])
  @@index([fullPath])
}

model FileChunk {
  id         String   @id @default(uuid())
  fileId     String
  blobId     String
  chunkIndex Int
  size       Int
  createdAt  DateTime @default(now())

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)
  blob Blob @relation(fields: [blobId], references: [id])

  @@unique([fileId, chunkIndex])
  @@index([fileId])
}

model Blob {
  id         String   @id @default(uuid())
  hash       String
  storageKey String
  size       Int
  refCount   Int
  createdAt  DateTime @default(now())

  chunks FileChunk[]

  @@unique([hash])
  @@index([refCount])
}

model UploadSession {
  id             String       @id @default(uuid())
  totalChunks    Int
  uploadedChunks Int
  totalSize      Int
  status         UploadStatus
  userId         String
  expiresAt      DateTime
  createdAt      DateTime     @default(now())

  file File?
  user User  @relation(fields: [userId], references: [id])
}

enum UploadStatus {
  active
  cancelled
  completed
  expired
}

enum Visibility {
  private
  public
  shared
}

model SharedLink {
  id          String    @id @default(uuid())
  fileId      String
  file        File      @relation(fields: [fileId], references: [id])
  expiresAt   DateTime?
  accessToken String? // optional access control

  createdAt DateTime @default(now())
}

model Job {
  id        String    @id @default(uuid())
  name      String
  userId    String
  User      User      @relation(fields: [userId], references: [id])
  requestId String
  attempts  Int       @default(0)
  status    JobStatus @default(enqueued)
  payload   Json
  result    Json?
  error     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum JobStatus {
  enqueued
  processing
  completed
  failed
}

model DownloadLink {
  id        String   @id @default(uuid())
  fileName  String
  requestId String
  createdAt DateTime @default(now())
  expiresAt DateTime
  userId    String
  User      User     @relation(fields: [userId], references: [id])
}

model BroadcastMessage {
  id       String   @id @default(uuid())
  content  String
  authorId String
  author   User     @relation(fields: [authorId], references: [id])
  sentAt   DateTime @default(now())
}
